# CloudGentic Gateway - Environment Variables
# Copy to .env and fill in values. NEVER commit .env to version control.

DEPLOYMENT_MODE=self-hosted

# Encryption (REQUIRED) - Generate with: openssl rand -hex 32
GATEWAY_MASTER_KEY=
GATEWAY_JWT_SECRET=

# Database
POSTGRES_USER=gateway
POSTGRES_PASSWORD=
POSTGRES_DB=cloudgentic_gateway
DATABASE_URL=postgresql+asyncpg://gateway:${POSTGRES_PASSWORD}@gateway-db:5432/cloudgentic_gateway

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@gateway-redis:6379/0

# URLs
API_URL=http://localhost:8421
DASHBOARD_URL=http://localhost:3000
PUBLIC_URL=http://localhost:8420

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twitter/X OAuth
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=

# Slack OAuth
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
